                    {"name": "api_key_name",       "expression": "api_key_name"},
                    {"name": "calls_1h",           "expression": "calls_1h"},
                    {"name": "calls_24h",          "expression": "calls_24h"},
                    {"name": "calls_ok_total",     "expression": "calls_ok_total"},
                    {"name": "calls_error_total",  "expression": "calls_error_total"},
                    {"name": "error_rate_pct",     "expression": "error_rate_pct"},
                    {"name": "last_call_at",       "expression": "last_call_at"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
