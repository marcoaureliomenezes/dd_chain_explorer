{
  "datasets": [
    {
      "name": "gas_by_type",
      "displayName": "Gas por Tipo de Transação",
      "query": "SELECT\n  type_transaction,\n  COUNT(*)                                                AS tx_count,\n  ROUND(AVG(gas_pct_of_block), 4)                        AS avg_gas_pct,\n  ROUND(AVG(CAST(gas_price AS DOUBLE) / 1e9), 4)        AS avg_gas_price_gwei,\n  ROUND(AVG(CAST(gas_limit AS DOUBLE)), 0)              AS avg_gas_limit\nFROM dev.s_apps.ethereum_gas_consume\nWHERE type_transaction IS NOT NULL\nGROUP BY type_transaction\nORDER BY tx_count DESC"
    },
    {
      "name": "gas_hourly",
      "displayName": "Gas Price por Hora e Tipo",
      "query": "SELECT\n  DATE_TRUNC('hour', tx_timestamp)                      AS hour_bucket,\n  type_transaction,\n  ROUND(AVG(CAST(gas_price AS DOUBLE) / 1e9), 4)       AS avg_gas_price_gwei,\n  ROUND(AVG(gas_pct_of_block), 4)                       AS avg_gas_pct,\n  COUNT(*)                                               AS tx_count\nFROM dev.s_apps.ethereum_gas_consume\nWHERE type_transaction IS NOT NULL\nGROUP BY 1, 2\nORDER BY 1 ASC, 2 ASC\nLIMIT 2000"
    },
    {
      "name": "gas_price_daily",
      "displayName": "Percentis de Gas Price por Dia",
      "query": "SELECT\n  DATE_TRUNC('day', tx_timestamp)                                                         AS day_bucket,\n  ROUND(PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY CAST(gas_price AS DOUBLE) / 1e9), 4) AS p50_gwei,\n  ROUND(PERCENTILE_CONT(0.75) WITHIN GROUP (ORDER BY CAST(gas_price AS DOUBLE) / 1e9), 4) AS p75_gwei,\n  ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY CAST(gas_price AS DOUBLE) / 1e9), 4) AS p95_gwei,\n  COUNT(*)                                                                                   AS tx_count\nFROM dev.s_apps.ethereum_gas_consume\nWHERE tx_timestamp IS NOT NULL\nGROUP BY 1\nORDER BY 1 ASC\nLIMIT 365"
    }
  ],
  "pages": [
    {
      "name": "gas_analytics_page",
      "displayName": "Gas Analytics",
      "layout": [
        {
          "widget": {
            "name": "pie_tx_by_type",
            "queries": [
              {
                "name": "main",
                "query": {
                  "datasetName": "gas_by_type",
                  "fields": [
                    {"name": "type_transaction", "expression": "type_transaction"},
                    {"name": "tx_count",         "expression": "tx_count"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "pie",
              "encodings": {
                "angle": {
                  "fieldName": "tx_count",
                  "displayName": "Transações"
                },
                "color": {
                  "fieldName": "type_transaction",
                  "displayName": "Tipo"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Distribuição de Txs por Tipo"
              }
            }
          },
          "position": {"x": 0, "y": 0, "width": 3, "height": 6}
        },
        {
          "widget": {
            "name": "bar_gas_pct_by_type",
            "queries": [
              {
                "name": "main",
                "query": {
                  "datasetName": "gas_by_type",
                  "fields": [
                    {"name": "type_transaction", "expression": "type_transaction"},
                    {"name": "avg_gas_pct",      "expression": "avg_gas_pct"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "type_transaction",
                  "scale": {"type": "ordinal"},
                  "displayName": "Tipo"
                },
                "y": [
                  {
                    "fieldName": "avg_gas_pct",
                    "scale": {"type": "quantitative"},
                    "displayName": "Avg Gas % do Bloco"
                  }
                ]
              },
              "frame": {
                "showTitle": true,
                "title": "Avg Gas % do Bloco por Tipo"
              }
            }
          },
          "position": {"x": 3, "y": 0, "width": 3, "height": 6}
        },
        {
          "widget": {
            "name": "line_gas_price_hourly",
            "queries": [
              {
                "name": "main",
                "query": {
                  "datasetName": "gas_hourly",
                  "fields": [
                    {"name": "hour_bucket",        "expression": "hour_bucket"},
                    {"name": "type_transaction",   "expression": "type_transaction"},
                    {"name": "avg_gas_price_gwei", "expression": "avg_gas_price_gwei"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "xy",
              "encodings": {
                "x": {
                  "fieldName": "hour_bucket",
                  "scale": {"type": "temporal"},
                  "displayName": "Hora"
                },
                "y": [
                  {
                    "fieldName": "avg_gas_price_gwei",
                    "scale": {"type": "quantitative"},
                    "displayName": "Avg Gas Price (Gwei)"
                  }
                ],
                "color": {
                  "fieldName": "type_transaction",
                  "displayName": "Tipo"
                }
              },
              "mark": {"type": "line"},
              "frame": {
                "showTitle": true,
                "title": "Avg Gas Price (Gwei) por Hora — por Tipo de Transação"
              }
            }
          },
          "position": {"x": 0, "y": 6, "width": 6, "height": 7}
        },
        {
